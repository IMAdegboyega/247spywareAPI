# Server Configuration
PORT=8080

# Public site + API base URLs (used inside email templates)
SITE_URL=http://localhost:3000
API_URL=http://localhost:8080

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# MongoDB Connection
# Atlas: copy from your cluster -> Connect -> Drivers (use the URI with srv).
# Local Docker: mongodb://localhost:27017
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=247techspyware

# Upload Configuration
UPLOAD_PATH=./uploads

# Latest News Expiry (in days)
LATEST_NEWS_EXPIRY_DAYS=21

# Optional: override the seeded admin credentials (used by cmd/seed only)
# ADMIN_EMAIL=admin@blog.com
# ADMIN_PASSWORD=admin123
# ADMIN_NAME=Admin

# ---------------------------------------------------------------------------
# Email delivery — we use Resend for both transactional mail (password resets,
# admin/author notifications) and newsletter blasts. They can share the same
# API key.
#
#   1. Sign up at https://resend.com.
#   2. API Keys -> Create. Copy the key (re_xxx) — shown only once.
#   3. Paste the SAME key into both *_SMTP_PASSWORD values below.
#
# From-address: use onboarding@resend.dev while testing. That address only
# delivers to the email registered on your Resend account.
#
# To send to anyone (subscribers, real users), verify a domain in Resend
# (Domains -> Add domain -> add the SPF/DKIM/DMARC records to your DNS),
# then swap the FROM addresses to ones on that domain — e.g.
# no-reply@247techspyware.com for transactional, newsletter@... for blasts.
# ---------------------------------------------------------------------------

# Transactional sender — password resets, admin/author notifications.
NOTIFICATION_SMTP_HOST=smtp.resend.com
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USERNAME=resend
NOTIFICATION_SMTP_PASSWORD=re_your_api_key_here
NOTIFICATION_SMTP_FROM=onboarding@resend.dev
NOTIFICATION_SMTP_FROM_NAME=247 Tech Spyware

# Newsletter sender — subscriber blasts when a post publishes.
NEWSLETTER_SMTP_HOST=smtp.resend.com
NEWSLETTER_SMTP_PORT=587
NEWSLETTER_SMTP_USERNAME=resend
NEWSLETTER_SMTP_PASSWORD=re_your_api_key_here
NEWSLETTER_SMTP_FROM=onboarding@resend.dev
NEWSLETTER_SMTP_FROM_NAME=247 Tech Spyware
