# Server Configuration
PORT=8080

# Public site + API base URLs (used inside email templates)
SITE_URL=http://localhost:3000
API_URL=http://localhost:8080

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# MongoDB Connection
# Atlas: copy from your cluster -> Connect -> Drivers (use the URI with srv).
# Local Docker: mongodb://localhost:27017
MONGODB_URI=mongodb+srv://247spywaretest:247spywaretest@cluster0.csyjazk.mongodb.net/?appName=Cluster0
MONGODB_DB=247techspyware

# Upload Configuration
UPLOAD_PATH=./uploads

# Latest News Expiry (in days)
LATEST_NEWS_EXPIRY_DAYS=21

# Optional: override the seeded admin credentials (used by cmd/seed only)
ADMIN_EMAIL=toromothankgod@gmail.com
# ADMIN_PASSWORD=admin123
# ADMIN_NAME=Admin

# ---------------------------------------------------------------------------
# Notification email (Gmail) — password resets + admin/author notifications.
#
# Gmail requires an App Password, not your normal Gmail password:
#   1. Turn on 2-Step Verification at https://myaccount.google.com/security
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail" -> "Other (247TechSpyware)"
#   4. Paste the 16-character password (no spaces) into NOTIFICATION_SMTP_PASSWORD
# ---------------------------------------------------------------------------
NOTIFICATION_SMTP_HOST=smtp.resend.com
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USERNAME=resend
NOTIFICATION_SMTP_PASSWORD=re_JUVknRTX_5JrRF1cfTJR56nJrx9LPfDTo
NOTIFICATION_SMTP_FROM=onboarding@resend.dev
NOTIFICATION_SMTP_FROM_NAME=247 Tech Spyware

# ---------------------------------------------------------------------------
# Newsletter email (Resend) — subscriber blasts when a post publishes.
#
# Sign up at https://resend.com -> API Keys -> Create. Then under SMTP:
#   Host: smtp.resend.com
#   Port: 587 (or 465)
#   Username: resend
#   Password: <your API key (re_xxx)>
# From-address: use onboarding@resend.dev while testing, or any address on a
# domain you've verified in the Resend dashboard.
# ---------------------------------------------------------------------------
NEWSLETTER_SMTP_HOST=smtp.resend.com
NEWSLETTER_SMTP_PORT=587
